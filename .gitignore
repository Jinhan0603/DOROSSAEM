# ===================================
# DORO 강사관리 시스템 .gitignore
# ===================================

# ─── 민감정보 파일 ───
# ⚠️ (주의) 정보파일 디렉토리 전체 - 절대 업로드 금지
(주의) 정보파일/
20260206_내부운영_강사등급제 도입/

# 모든 엑셀 파일 (개인정보 포함 가능)
*.xlsx
*.xls

# 임시 스크립트
*.bat

# 개인정보가 포함된 원본 엑셀 파일
data/source/
data/normalized/

# 민감정보 CSV (주민번호, 계좌 등)
*_sensitive_*.csv
*_sensitive_*.json

# ─── OS 파일 ───
.DS_Store
Thumbs.db
Desktop.ini

# ─── IDE ───
.vscode/
.idea/
*.swp
*.swo

# ─── Temp ───
*.tmp
*.bak
~$*

# ─── Node (향후) ───
node_modules/
package-lock.json

# ─── clasp (구버전) ───
.clasp.json
